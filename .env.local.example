# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (SSO)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe Configuration
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_FOUNDERS_MONTHLY=
STRIPE_PRICE_FOUNDERS_YEARLY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp AI feature
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_INSIGHTS_TEMPLATE_NAME=
WHATSAPP_AUDIO_CONFIRM_TEMPLATE_NAME=
WHATSAPP_AUDIO_MAX_BYTES=10000000
GROQ_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM="Florim Finanças <financasflorim@yourdomain.com>"

# RevenueCat (mobile IAP webhook)
REVENUECAT_WEBHOOK_SECRET=

# Cron authentication (shared secret for /api/cron/* routes)
CRON_SECRET=

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
